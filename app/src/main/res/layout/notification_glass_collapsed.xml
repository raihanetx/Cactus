<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root_collapsed"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFFFF"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- TITLE -->
    <TextView
        android:id="@+id/track_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Word Forward"
        android:textColor="#FF171717"
        android:textSize="14sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end" />

    <!-- TIMELINE with tap-to-seek zones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/time_current"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:text="0:00"
            android:textColor="#FF404040"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginRight="6dp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="18dp"
            android:layout_weight="1">

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_gravity="center_vertical"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/notif_progress" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/zone_1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text=""
                    android:background="@null"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/zone_2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text=""
                    android:background="@null"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/zone_3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text=""
                    android:background="@null"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/zone_4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text=""
                    android:background="@null"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/zone_5"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text=""
                    android:background="@null"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/time_duration"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="left"
            android:text="0:00"
            android:textColor="#FFA3A3A3"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginLeft="6dp" />
    </LinearLayout>

    <!-- CONTROLS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/btn_backward"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="-10s"
            android:textColor="#FF525252"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <FrameLayout
            android:id="@+id/btn_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/notif_play_button"
            android:padding="1dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp">

            <TextView
                android:id="@+id/btn_play_pause_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Play"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@null" />
        </FrameLayout>

        <TextView
            android:id="@+id/btn_forward"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="+10s"
            android:textColor="#FF525252"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
